#!/usr/bin/env python3
"""
Stoppe les torrents termines sur trackers publics ou sans ratio (ygg.gratis, etc.)
des que le ratio atteint STOP_RATIO.
"""
import sys
import os
import xml.etree.ElementTree as ET
from datetime import datetime
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from rtorrent_scgi import scgi_call, download_list, multicall, scgi_simple

# Ratio minimum pour stopper (2.0 = 2000 en interne rtorrent)
STOP_RATIO = 2000

# Trackers "sans ratio" -- flag prive pour DHT/PEX mais pas de ratio cote tracker
NO_RATIO_HOSTS = [
    'ygg.re', 'ygg.gratis', 'yggtorrent.pics', 'yggtorrent.si',
    'anidex.info', 'nyaa.si', 'animebytes.tv',
    'opentrackr.org', 'tracker.openbittorent.com',
    'tracker.leechers-paradise.org', 'tracker.coppersurfer.tk',
    '9.rarbg.to', '9.rarbg.me',
]

def log(msg):
    print(f'[{datetime.now().strftime("%H:%M:%S")}] {msg}', flush=True)

def is_no_ratio_host(url: str) -> bool:
    from urllib.parse import urlparse
    host = urlparse(url).hostname or ''
    host = host.lower()
    return any(host == d or host.endswith('.' + d) for d in NO_RATIO_HOSTS)

def tracker_urls(hash_: str) -> list:
    xml = (
        '<?xml version="1.0"?><methodCall><methodName>t.multicall</methodName><params>'
        f'<param><value><string>{hash_}</string></value></param>'
        '<param><value><string></string></value></param>'
        '<param><value><string>t.url=</string></value></param>'
        '</params></methodCall>'
    )
    resp = scgi_call(xml)
    root = ET.fromstring(resp)
    urls = []
    for s in root.iter('string'):
        u = s.text.strip() if s.text else ''
        if u.startswith('http') or u.startswith('udp'):
            urls.append(u)
    return urls

def should_stop(is_private: int, urls: list) -> bool:
    if is_private == 0:
        return True  # tracker public classique
    # Prive : stopper seulement si TOUS les trackers sont dans la liste sans ratio
    if not urls:
        return False
    return all(is_no_ratio_host(u) for u in urls)

hashes = download_list()
if not hashes:
    log('Aucun torrent actif')
    sys.exit(0)

# Batch : name + complete + is_private + is_active + ratio
calls = []
for h in hashes:
    for method in ('d.name', 'd.complete', 'd.is_private', 'd.is_active', 'd.ratio'):
        calls.append({'method': method, 'params': [h]})

vals = multicall(calls)
total_stopped = 0

for i, h in enumerate(hashes):
    base = i * 5
    name       = vals[base]     if base   < len(vals) else ''
    complete   = int(vals[base+1]) if base+1 < len(vals) else 0
    is_private = int(vals[base+2]) if base+2 < len(vals) else 1
    is_active  = int(vals[base+3]) if base+3 < len(vals) else 0
    ratio      = int(vals[base+4]) if base+4 < len(vals) else 0

    if complete != 1 or is_active != 1 or ratio < STOP_RATIO:
        continue

    urls = tracker_urls(h) if is_private == 1 else []

    if not should_stop(is_private, urls):
        continue

    scgi_simple('d.stop', h)
    scgi_simple('d.close', h)

    tracker_host = urls[0].split('/')[2] if urls else 'public'
    log(f'stop "{name[:60]}" ratio={ratio/1000:.1f}x private={is_private} tracker={tracker_host}')
    total_stopped += 1

log(f'DONE - {total_stopped} torrent(s) stoppes sur {len(hashes)} verifies')
