#!/usr/bin/env python3
"""
rtorrent-check-space — Hook event.download.inserted_new

Verifie si le torrent qui vient d'etre insere rentre sur le NVMe.
  - Assez de place : affiche le chemin NVMe sur stdout, cree un symlink
    RAID/name -> NVMe/name pour que sharebox voie le torrent.
  - Pas assez de place : affiche le chemin RAID sur stdout.

stdout est capture par rtorrent via execute.capture pour d.directory.set.
Les logs vont sur stderr pour ne pas polluer la capture.

Appele par rtorrent avec hash, name, size_bytes et is_multi_file en arguments.
"""

import sys
import os
import shutil
from pathlib import Path


LOG_FILE = Path('/var/www/sharebox/data/logs/check-space.log')


def log(msg):
    print(msg, file=sys.stderr, flush=True)
    try:
        with open(LOG_FILE, 'a') as f:
            from datetime import datetime
            f.write(f'{datetime.now():%Y-%m-%d %H:%M:%S} {msg}\n')
    except Exception:
        pass


def load_conf():
    path = Path(__file__).parent / 'seedbox.conf'
    conf = {}
    with open(path) as f:
        for line in f:
            line = line.strip()
            if line and not line.startswith('#') and '=' in line:
                k, v = line.split('=', 1)
                conf[k.strip()] = v.strip()
    return conf


def check_space(hash_, name, size_bytes, is_multi, nvme_downloads, raid_downloads, margin_gb):
    """Retourne le chemin du repertoire cible (NVMe ou RAID)."""
    free_bytes   = shutil.disk_usage(nvme_downloads).free
    needed_bytes = size_bytes + margin_gb * (1024 ** 3)
    torrent_gb   = size_bytes / (1024 ** 3)
    free_gb      = free_bytes / (1024 ** 3)

    if free_bytes >= needed_bytes:
        # Rentre sur NVMe : symlink RAID/name -> NVMe/name pour que sharebox le voie
        if name:
            symlink     = Path(raid_downloads) / name
            nvme_target = Path(nvme_downloads) / name
            if not symlink.exists() and not symlink.is_symlink():
                Path(raid_downloads).mkdir(parents=True, exist_ok=True)
                symlink.symlink_to(nvme_target)
                log(f'[check-space] symlink cree : {symlink} -> {nvme_target}')
            else:
                log(f'[check-space] symlink skip (existe deja) : {symlink}')
        log(
            f'[check-space] NVMe OK - {torrent_gb:.1f} GB, {free_gb:.1f} GB libre'
            + (f' : {name}' if name else '')
        )
        return nvme_downloads
    else:
        log(
            f'[check-space] RAID - {torrent_gb:.1f} GB > {free_gb:.1f} GB libre'
            f' (marge {margin_gb} GB) : {name}'
        )
        return raid_downloads


def main():
    if len(sys.argv) < 4:
        sys.exit(0)
    hash_      = sys.argv[1].strip()
    name       = sys.argv[2].strip()
    size_bytes = int(sys.argv[3].strip() or '0')
    is_multi   = int(sys.argv[4].strip() or '0') if len(sys.argv) > 4 else 0
    if not hash_:
        sys.exit(0)

    conf           = load_conf()
    nvme_downloads = conf['NVME_DOWNLOADS']
    raid_downloads = conf['RAID_DOWNLOADS']
    margin_gb      = int(conf.get('NVME_MARGIN_GB', '50'))

    try:
        target = check_space(hash_, name, size_bytes, is_multi, nvme_downloads, raid_downloads, margin_gb)
    except Exception as e:
        log(f'[check-space] ERREUR : {e} - fallback RAID')
        target = raid_downloads

    # stdout = capture par rtorrent pour d.directory.set (pas de newline)
    sys.stdout.write(target)


if __name__ == '__main__':
    main()
