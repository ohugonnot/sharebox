#!/bin/bash
# Monitoring seedbox : I/O disque + bande passante reseau + upload qBittorrent
LOGFILE="${SEEDBOX_LOG_DIR:-/var/www/sharebox/data/logs}/seedbox-monitor.log"
CRASH_LOGFILE="${SEEDBOX_LOG_DIR:-/var/www/sharebox/data/logs}/qbittorrent-crashes.log"
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
IFACE="${SEEDBOX_IFACE:-enp59s0f0}"
RAID="md0"
NVME="nvme0n1"
QB_USER="ropixv2"
QB_URL="http://localhost:8181"
QB_LOGIN="ropixv2"
QB_PASS="Lip8NebW8Z8HrbX"
QB_COOKIE=""

read_net() {
    grep "$IFACE:" /proc/net/dev | awk '{print $2, $10}'
}

read_disk() {
    grep " $1 " /proc/diskstats | awk '{print $6, $10}'
}

qb_login() {
    QB_COOKIE=$(curl -s -c - "$QB_URL/api/v2/auth/login" \
        -d "username=$QB_LOGIN&password=$QB_PASS" 2>/dev/null | grep SID | awk '{print $NF}')
}

qb_upload_mbps() {
    # Essayer avec le cookie existant, re-login si besoin
    local speed
    speed=$(curl -s -b "SID=$QB_COOKIE" "$QB_URL/api/v2/transfer/info" 2>/dev/null \
        | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('up_info_speed',0)//1048576)" 2>/dev/null)
    if [ -z "$speed" ] || [ "$speed" = "" ]; then
        qb_login
        speed=$(curl -s -b "SID=$QB_COOKIE" "$QB_URL/api/v2/transfer/info" 2>/dev/null \
            | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('up_info_speed',0)//1048576)" 2>/dev/null)
    fi
    echo "${speed:-0}"
}

# Login initial
qb_login

prev_net=($(read_net))
prev_raid=($(read_disk $RAID))
prev_nvme=($(read_disk $NVME))
prev_time=$(date +%s)
prev_qb_pid=""

sleep 10

while true; do
    now=$(date +%s)
    cur_net=($(read_net))
    cur_raid=($(read_disk $RAID))
    cur_nvme=($(read_disk $NVME))

    dt=$(( now - prev_time ))
    [ $dt -eq 0 ] && dt=1

    rx_mb=$(( (${cur_net[0]} - ${prev_net[0]}) / dt / 1048576 ))
    tx_mb=$(( (${cur_net[1]} - ${prev_net[1]}) / dt / 1048576 ))
    raid_rd=$(( (${cur_raid[0]} - ${prev_raid[0]}) * 512 / dt / 1048576 ))
    raid_wr=$(( (${cur_raid[1]} - ${prev_raid[1]}) * 512 / dt / 1048576 ))
    nvme_rd=$(( (${cur_nvme[0]} - ${prev_nvme[0]}) * 512 / dt / 1048576 ))
    nvme_wr=$(( (${cur_nvme[1]} - ${prev_nvme[1]}) * 512 / dt / 1048576 ))

    cache_gb=$(awk '/^Cached:/{printf "%.1f", $2/1048576}' /proc/meminfo)
    qb_up=$(qb_upload_mbps)

    # PID-based crash detection for qBittorrent
    qb_pid=$(pgrep -u "$QB_USER" qbittorrent 2>/dev/null | head -1)
    qb_fds="-"
    if [ -n "$qb_pid" ]; then
        qb_fds=$(ls /proc/$qb_pid/fd 2>/dev/null | wc -l)
    fi
    if [ -n "$prev_qb_pid" ] && [ "$qb_pid" != "$prev_qb_pid" ]; then
        ts="$(date '+%Y-%m-%d %H:%M:%S')"
        if [ -n "$qb_pid" ]; then
            echo "$ts [RESTART] PID $prev_qb_pid → $qb_pid | contexte: up=${qb_up}MB/s raid_rd=${raid_rd}MB/s fds=${qb_fds}" >> "$CRASH_LOGFILE"
        else
            echo "$ts [DOWN] qBittorrent PID $prev_qb_pid disparu | contexte: up=${qb_up}MB/s raid_rd=${raid_rd}MB/s" >> "$CRASH_LOGFILE"
        fi
    fi
    prev_qb_pid="$qb_pid"

    # Ratio disque lu / upload (efficacite cache OS)
    total_disk_rd=$((raid_rd + nvme_rd))
    if [ "$qb_up" -gt 0 ]; then
        disk_eff=$(awk "BEGIN {printf \"%.1fx\", $total_disk_rd / $qb_up}")
    else
        disk_eff="idle"
    fi

    echo "$(date '+%Y-%m-%d %H:%M:%S') | NET rx=${rx_mb}MB/s tx=${tx_mb}MB/s | RT_UP=${qb_up}MB/s | FDS=${qb_fds} | RAID rd=${raid_rd}MB/s wr=${raid_wr}MB/s | NVME rd=${nvme_rd}MB/s wr=${nvme_wr}MB/s | CACHE=${cache_gb}GB | DISKEFF=${disk_eff}" >> "$LOGFILE"

    prev_net=("${cur_net[@]}")
    prev_raid=("${cur_raid[@]}")
    prev_nvme=("${cur_nvme[@]}")
    prev_time=$now

    sleep 10
done
