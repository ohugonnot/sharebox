#!/usr/bin/env python3
"""
raid-to-nvme — Deplace manuellement un torrent du RAID0 vers le NVMe.

Usage : python3 raid-to-nvme <nom_ou_motif>

Supporte qBittorrent (API REST) avec fallback rtorrent (SCGI).
"""

import sys
import os
import json
import shutil
import subprocess
import time
import urllib.request
import urllib.parse
from pathlib import Path
from datetime import datetime

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))


def load_conf():
    path = Path(__file__).parent / 'seedbox.conf'
    conf = {}
    with open(path) as f:
        for line in f:
            line = line.strip()
            if line and not line.startswith('#') and '=' in line:
                k, v = line.split('=', 1)
                conf[k.strip()] = v.strip()
    return conf


def log(msg):
    print(f'[{datetime.now().strftime("%H:%M:%S")}] {msg}', flush=True)


def detect_backend():
    try:
        r = subprocess.run(['pgrep', '-x', 'qbittorrent-nox'],
                           capture_output=True, text=True, timeout=3)
        if r.returncode == 0 and r.stdout.strip():
            return 'qbt'
    except Exception:
        pass
    sock = os.environ.get('RTORRENT_SOCK', '/var/run/rtorrent/ropixv2.sock')
    if os.path.exists(sock):
        return 'rt'
    return 'qbt'


# ── qBittorrent ──────────────────────────────────────────────────────────────

_qb_cookie = None
QB_URL = QB_USER = QB_PASS = None


def qb_request(endpoint, data=None):
    global _qb_cookie
    url = f'{QB_URL}{endpoint}'
    if data:
        data = urllib.parse.urlencode(data).encode()
    req = urllib.request.Request(url, data=data)
    if _qb_cookie:
        req.add_header('Cookie', _qb_cookie)
    resp = urllib.request.urlopen(req, timeout=30)
    sc = resp.headers.get('Set-Cookie')
    if sc:
        _qb_cookie = sc.split(';')[0]
    return resp.read().decode()


def qb_login():
    qb_request('/api/v2/auth/login', {'username': QB_USER, 'password': QB_PASS})


def qb_run(pattern, nvme, raid):
    qb_login()
    torrents = json.loads(qb_request('/api/v2/torrents/info'))

    matches = [t for t in torrents if pattern in t.get('name', '').lower()]

    if not matches:
        log(f'Aucun torrent ne correspond a "{pattern}"')
        sys.exit(1)
    if len(matches) > 1:
        log(f'{len(matches)} torrents correspondent, sois plus precis :')
        for m in matches:
            log(f'  {m["name"]}')
        sys.exit(1)

    t = matches[0]
    name     = t['name']
    h        = t['hash']
    save_path = t.get('save_path', '')
    size_gb  = (t.get('total_size', 0) or t.get('size', 0)) / (1024 ** 3)
    is_active = t.get('state', '') not in ('pausedUP', 'pausedDL', 'stoppedUP', 'stoppedDL')

    log(f'Torrent : {name}')
    log(f'  repertoire actuel : {save_path}')
    log(f'  taille : {size_gb:.1f} GB  |  actif : {is_active}')

    if save_path.startswith(nvme):
        log(f'ERREUR : le torrent est deja sur NVMe ({save_path})')
        sys.exit(1)

    if not save_path.startswith(raid):
        log(f'ERREUR : le torrent n\'est pas sur RAID ({save_path})')
        sys.exit(1)

    free_gb = shutil.disk_usage(nvme).free / (1024 ** 3)
    if free_gb < size_gb + 50:
        log(f'ERREUR : NVMe trop plein ({free_gb:.1f} GB libre, besoin de {size_gb + 50:.1f} GB)')
        sys.exit(1)

    log(f'NVMe libre : {free_gb:.1f} GB - OK')

    # qBittorrent setLocation deplace les fichiers automatiquement
    log('Deplacement via setLocation...')
    qb_request('/api/v2/torrents/setLocation', {
        'hashes': h,
        'location': nvme,
    })
    qb_request('/api/v2/torrents/setCategory', {
        'hashes': h,
        'category': 'hot',
    })

    # Creer symlink RAID/name → NVMe/name pour que ShareBox voie le torrent
    symlink = Path(raid) / name
    nvme_target = Path(nvme) / name

    # Attendre que qBittorrent deplace les fichiers
    log('Attente du deplacement...')
    for _ in range(120):  # max 2 min
        time.sleep(1)
        if nvme_target.exists():
            break
    else:
        log('WARN : timeout attente deplacement, le symlink sera peut-etre premature')

    # Supprimer l'ancien dossier/fichier RAID et creer le symlink
    if symlink.exists() and not symlink.is_symlink():
        # qBittorrent a deja deplace, mais l'ancien dossier vide peut rester
        try:
            if symlink.is_dir():
                shutil.rmtree(symlink)
            else:
                symlink.unlink()
        except Exception:
            pass

    if not symlink.exists() and not symlink.is_symlink():
        symlink.symlink_to(nvme_target)
        log(f'Symlink cree : {symlink} -> {nvme_target}')

    log(f'OK - {name} est maintenant sur NVMe')


# ── rtorrent fallback ────────────────────────────────────────────────────────

def rt_run(pattern, nvme, raid):
    from rtorrent_scgi import download_list, multicall, scgi_simple

    hashes = download_list()
    if not hashes:
        log('Aucun torrent dans rtorrent')
        sys.exit(1)

    FIELDS = ('d.name', 'd.directory', 'd.size_bytes', 'd.is_open', 'd.is_multi_file')
    calls = [{'method': m, 'params': [h]} for h in hashes for m in FIELDS]
    vals  = multicall(calls)
    N     = len(FIELDS)

    matches = []
    for i, h in enumerate(hashes):
        base = i * N
        name = vals[base] or ''
        if pattern in name.lower():
            matches.append({
                'hash':     h,
                'name':     name,
                'dir':      vals[base + 1] or '',
                'size':     int(vals[base + 2] or 0),
                'is_open':  int(vals[base + 3] or 0),
                'is_multi': int(vals[base + 4] or 0),
            })

    if not matches:
        log(f'Aucun torrent ne correspond a "{pattern}"')
        sys.exit(1)
    if len(matches) > 1:
        log(f'{len(matches)} torrents correspondent, sois plus precis :')
        for m in matches:
            log(f'  {m["name"]}')
        sys.exit(1)

    t = matches[0]
    name     = t['name']
    hash_    = t['hash']
    was_open = t['is_open']
    is_multi = t['is_multi']
    size_gb  = t['size'] / (1024 ** 3)

    log(f'Torrent : {name}')
    log(f'  repertoire actuel : {t["dir"]}')
    log(f'  taille : {size_gb:.1f} GB  |  ouvert : {was_open}')

    if not t['dir'].startswith(raid):
        log(f'ERREUR : le torrent n\'est pas sur RAID ({t["dir"]})')
        sys.exit(1)

    src = Path(raid) / name
    if not src.exists():
        log(f'ERREUR : source introuvable : {src}')
        sys.exit(1)

    free_gb = shutil.disk_usage(nvme).free / (1024 ** 3)
    if free_gb < size_gb + 10:
        log(f'ERREUR : NVMe trop plein ({free_gb:.1f} GB libre, besoin de {size_gb + 10:.1f} GB)')
        sys.exit(1)

    log(f'NVMe libre : {free_gb:.1f} GB - OK')

    dst_nvme = Path(nvme) / name
    dst_tmp  = Path(nvme) / (name + '.raid-tmp')
    Path(nvme).mkdir(parents=True, exist_ok=True)

    if was_open:
        log('pause...')
        scgi_simple('d.pause', hash_)
        time.sleep(2)

    try:
        if is_multi:
            cmd = ['rsync', '-a', '--delete', '--info=progress2',
                   str(src) + '/', str(dst_tmp) + '/']
        else:
            cmd = ['rsync', '-a', '--info=progress2', str(src), str(dst_tmp)]

        log(f'rsync {"multi" if is_multi else "single"} -> {dst_tmp.name}')
        result = subprocess.run(cmd)
        if result.returncode != 0:
            raise RuntimeError(f'rsync exit {result.returncode}')

        scgi_simple('d.directory.set', hash_, nvme)
        scgi_simple('d.save_full_session', hash_)

        if src.is_symlink():
            src.unlink()
        elif src.is_dir():
            shutil.rmtree(src)
        else:
            src.unlink()

        dst_tmp.rename(dst_nvme)
        src.symlink_to(dst_nvme)

        log(f'OK - {name} est maintenant sur NVMe, symlink cree sur RAID')

    except Exception as e:
        log(f'ERREUR : {e}')
        if dst_tmp.exists():
            shutil.rmtree(dst_tmp) if dst_tmp.is_dir() else dst_tmp.unlink()
        sys.exit(1)

    finally:
        if was_open:
            scgi_simple('d.resume', hash_)
            log('resume')


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    global QB_URL, QB_USER, QB_PASS

    if len(sys.argv) < 2:
        print(f'Usage: {sys.argv[0]} <nom_ou_motif>', file=sys.stderr)
        sys.exit(1)

    pattern = sys.argv[1].lower()
    conf = load_conf()
    nvme = conf['NVME_DOWNLOADS']
    raid = conf['RAID_DOWNLOADS']

    backend = detect_backend()
    log(f'Backend: {backend}')

    if backend == 'qbt':
        QB_URL  = conf.get('QBITTORRENT_URL', 'http://127.0.0.1:8181')
        QB_USER = conf.get('QBITTORRENT_USER', 'ropixv2')
        QB_PASS = conf.get('QBITTORRENT_PASS', 'Lip8NebW8Z8HrbX')
        qb_run(pattern, nvme, raid)
    else:
        rt_run(pattern, nvme, raid)


if __name__ == '__main__':
    main()
